# ============================================================
# Auth — choose ONE method
# ============================================================

# Option A: Claude Max/Pro subscription (recommended if you have Max — $0)
# Generate the token by running:    claude setup-token
# Then paste it below.
CLAUDE_CODE_OAUTH_TOKEN=

# Option B: Anthropic API key (standard, ~$5 dev cost with Haiku)
# Get one at: https://console.anthropic.com/settings/keys
# ANTHROPIC_API_KEY=

# ============================================================
# Model selection
# ============================================================
CLAUDE_DEV_MODEL=claude-haiku-4-5-20251001
CLAUDE_PROD_MODEL=claude-sonnet-4-6

# ============================================================
# Data paths
# ============================================================
RETAIL_DATA_PATH=data/retail.parquet
SEGMENTS_PATH=data/customer_segments.csv
DEFINITIONS_PATH=data/definitions.md
